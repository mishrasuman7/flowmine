# =============================================================================
# FlowMine - Web environment template
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DYNAMODB_EVENTS_TABLE=flowmine-events

# -----------------------------------------------------------------------------
# Aurora PostgreSQL
# -----------------------------------------------------------------------------
AURORA_HOST=
AURORA_PORT=5432
AURORA_DATABASE=flowmine
AURORA_USERNAME=flowmine_admin
AURORA_PASSWORD=

# -----------------------------------------------------------------------------
# Google Gemini (skill generation, pattern interpretation, AND embeddings)
# Get a free key at https://aistudio.google.com/app/apikey — no payment
# method required for the development quota that covers the demo flow.
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Pusher (realtime dashboard updates)
# -----------------------------------------------------------------------------
PUSHER_APP_ID=
NEXT_PUBLIC_PUSHER_KEY=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000
TEAM_ID=demo_team_001
